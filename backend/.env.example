# ============================================================
# Backend Franck Rouane Photographie - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne JAMAIS committer .env dans git.
# ============================================================

# ── Prodigi Print-on-Demand ──────────────────────────────────
# Obtenir la clé sur : https://dashboard.prodigi.com/api-keys
PRODIGI_API_KEY=your_prodigi_api_key_here
PRODIGI_ENV=sandbox

# ── Stripe Paiements ─────────────────────────────────────────
# Clés disponibles sur : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Base de données MongoDB ──────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=frouane_photo

# ── Application ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://frouanephotographie.com

# ── Vercel Blob (serveur uniquement) ────────────────────────
# Token RW du store Vercel Blob "frouanephotographie-blob"
# Ne jamais l'exposer au frontend.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Sécurité ─────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_64_char_hex_string_here
