# ─── Backend ───
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=frouane_photo

# Prodigi Print API
# sandbox: api.sandbox.prodigi.com (test, pas de charge)
# live: api.prodigi.com (production, commandes réelles)
PRODIGI_ENV=sandbox
PRODIGI_API_KEY=your-prodigi-api-key
PRODIGI_ASSET_BASE_URL=

# CORS
CORS_ORIGINS=http://localhost:3000,https://frouanephotographie.com
FRONTEND_URL=http://localhost:3000

# Stripe
# Test keys: pk_test_... / sk_test_...
# Live keys: pk_live_... / sk_live_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
ADMIN_DEBUG_ENABLED=false

# ─── Frontend ───
REACT_APP_BACKEND_URL=http://localhost:8000
REACT_APP_GA4_ID=G-XXXXXXXXXX
